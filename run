#!/usr/bin/env bash
set -euo pipefail

DIR="$(cd "$(dirname "$0")" && pwd)"
VENV="$DIR/.venv"

# Generate SPECTR.desktop shortcut in the project folder
cat > "$DIR/SPECTR.desktop" <<EOF
[Desktop Entry]
Type=Application
Name=SPECTR
Comment=Elite Dangerous Companion — LCARS UI
Exec=$DIR/run
Path=$DIR
Icon=$DIR/spectr/data/icon.svg
Terminal=false
Categories=Game;
StartupNotify=true
EOF
chmod +x "$DIR/SPECTR.desktop"

if [ ! -d "$VENV" ]; then
    echo "Creating virtual environment..."
    python3 -m venv "$VENV"
fi

if ! "$VENV/bin/python" -c "import PySide6" 2>/dev/null; then
    echo "Installing PySide6..."
    "$VENV/bin/pip" install PySide6
fi

exec "$VENV/bin/python" "$DIR/main.py"

#!/usr/bin/env bash
set -euo pipefail
DIR="$(cd "$(dirname "$0")" && pwd)"
VENV="$DIR/.venv"
PYTHON="$VENV/bin/python3"

TOOLS=(
  "web:Web UI server (cockpit + blackbox + ship + missions)"
  "backup:Backup or restore journals"
)

ensure_venv() {
  if [ ! -d "$VENV" ]; then
    echo "Creating virtual environment..."
    python3 -m venv "$VENV"
  fi
}

ensure_deps() {
  "$VENV/bin/pip" install --quiet -e .
}

check_config() {
  if [ ! -f "$DIR/config.json" ]; then
    echo "Config not found. Creating..."
    "$PYTHON" -c "import json; open('$DIR/config.json','w').write(json.dumps({'journal_path': ''}, indent=2))"
    config_menu
  fi
}

config_menu() {
  local choice
  while true; do
    clear
    echo -e "\033[1;33mConfiguration\033[0m"
    echo ""
    local jrnl=$("$PYTHON" -c "import json; print(json.load(open('$DIR/config.json')).get('journal_path',''))" 2>/dev/null || true)
    local inara=$("$PYTHON" -c "import json; print(json.load(open('$DIR/config.json')).get('inara',{}).get('api_key','(not set)'))" 2>/dev/null || true)
    local edsm=$("$PYTHON" -c "import json; print(json.load(open('$DIR/config.json')).get('edsm',{}).get('api_key','(not set)'))" 2>/dev/null || true)
    echo -e "  1)  \033[36mJournal path\033[0m  — $jrnl"
    echo -e "  2)  \033[32mInara API key\033[0m  — $inara"
    echo -e "  3)  \033[33mEDSM API key\033[0m   — $edsm"
    echo -e "  b)  \033[1;31mBack\033[0m"
    echo ""
    read -rp "Select: " choice
    case "$choice" in
      b|B) return ;;
      1) config_set journal_path "Journal path" ;;
      2) config_set inara_key "Inara API key" ;;
      3) config_set edsm_key "EDSM API key" ;;
      *) echo "Invalid choice" ; sleep 1 ;;
    esac
  done
}

config_set() {
  local key="$1" label="$2"
  local cur=$("$PYTHON" -c "
import json
cfg = json.load(open('$DIR/config.json'))
if '$key' == 'journal_path':
    print(cfg.get('journal_path', ''))
elif '$key' == 'inara_key':
    print(cfg.get('inara', {}).get('api_key', ''))
elif '$key' == 'edsm_key':
    print(cfg.get('edsm', {}).get('api_key', ''))
" 2>/dev/null || true)
  echo ""
  printf "$label [%s]: " "${cur:-(none)}"
  read -r val
  if [ -z "$val" ]; then
    echo "Keeping current value."
    sleep 1
    return
  fi
  "$PYTHON" -c "
import json
cfg = json.load(open('$DIR/config.json'))
if '$key' == 'journal_path':
    cfg['journal_path'] = '$val'
elif '$key' == 'inara_key':
    cfg.setdefault('inara', {})['api_key'] = '$val'
elif '$key' == 'edsm_key':
    cfg.setdefault('edsm', {})['api_key'] = '$val'
cfg.setdefault('inara', {}).setdefault('api_url', 'https://api.inara.cz/v1/')
cfg.setdefault('edsm', {}).setdefault('api_url', 'https://www.edsm.net/api/')
with open('$DIR/config.json', 'w') as f:
    json.dump(cfg, f, indent=2)
"
  echo "Updated."
  sleep 1
}

free_port() {
  local port="${1:-8000}"
  local pid
  pid=$(ss -tlnp "sport = :$port" 2>/dev/null | grep -oP 'pid=\K[0-9]+') || true
  if [ -n "$pid" ]; then
    echo "Port $port in use by PID $pid. Killing..."
    kill "$pid" 2>/dev/null || true
    sleep 0.5
  fi
}

ensure_db() {
  if [ ! -f "$DIR/blackbox/blackbox.db" ] && [ -f "$DIR/config.json" ]; then
    if JRNL=$(python3 -c "
import json
cfg = json.load(open('$DIR/config.json'))
print(cfg.get('journal_path', ''))
" 2>/dev/null) && [ -n "$JRNL" ]; then
      echo "No blackbox.db found. Scanning journals..."
      "$PYTHON" -c "
from pathlib import Path
from blackbox.store import Store
from blackbox.recorder import Recorder
store = Store('$DIR/blackbox/blackbox.db')
rec = Recorder(store, Path('$JRNL'))
rec.catch_up()
store.close()
" 2>&1 || true
    fi
  fi
}

show_menu() {
  local RST="\033[0m" BLD="\033[1m"
  local COLORS=("\033[36m" "\033[32m" "\033[33m" "\033[34m" "\033[35m")

  echo -e "\033[90m@@@@@@   @@@@@@@   @@@@@@@@   @@@@@@@  @@@@@@@  @@@@@@@"
  echo -e "@@@@@@@   @@@@@@@@  @@@@@@@@  @@@@@@@@  @@@@@@@  @@@@@@@@"
  echo -e "!@@       @@!  @@@  @@!       !@@         @@!    @@!  @@@"
  echo -e "!@!       !@!  @!@  !@!       !@!         !@!    !@!  !@!"
  echo -e "!!@@!!    @!@@!@!   @!!!:!    !@!         @!!    @!@!!@!"
  echo -e " !!@!!!   !!@!!!    !!!!!:    !!!         !!!    !!@!@!"
  echo -e "     !:!  !!:       !!:       :!!         !!:    !!: :!!"
  echo -e "    !:!   :!:       :!:       :!:         :!:    :!:  !:!"
  echo -e ":::: ::    ::        :: ::::   ::: :::     ::    ::   :::"
  echo -e ":: : :     :        : :: ::    :: :: :     :      :   : :"
  echo -e "\033[0m"
  echo -e "\033[1;33mElite Dangerous Tool Suite\033[0m"
  echo ""
  for i in "${!TOOLS[@]}"; do
    name="${TOOLS[$i]%%:*}"
    desc="${TOOLS[$i]#*:}"
    echo -e "  $((i+1)))  ${BLD}${COLORS[$i]}$name${RST}  — $desc"
  done
  echo -e "  q)  \033[1;31mQuit\033[0m"
  echo -e "  c)  \033[1;36mConfig\033[0m — journal, Inara, EDSM"
  echo -e "  b)  \033[1;35mBackup\033[0m — backup / restore / list journals"
  echo ""
}

if [ $# -gt 0 ]; then
  ensure_venv
  ensure_deps
  check_config
  ensure_db
  TOOL="$1"
  shift
  case "$TOOL" in
    config)   config_menu ; exit 0 ;;
    web)      free_port 8000; exec "$PYTHON" -m uvicorn webui.server:app --host 0.0.0.0 --port 8000 "$@" ;;
    backup)   exec "$PYTHON" "$DIR/tools_backup.py" backup "$@" ;;
    restore)  exec "$PYTHON" "$DIR/tools_backup.py" restore "$@" ;;
    *)
      echo "Unknown tool: $TOOL"
      echo "Available: config, web, backup, restore"
      exit 1
      ;;
  esac
fi

ensure_venv
ensure_deps
check_config     # creates config.json if missing
ensure_db        # populate blackbox/blackbox.db from journals if absent

while true; do
  clear
  show_menu
  read -rp "Select tool: " choice
  case "$choice" in
    q|Q) echo "Bye."; exit 0 ;;
    c|C) config_menu ;;
    1)   free_port 8000; exec "$PYTHON" -m uvicorn webui.server:app --host 0.0.0.0 --port 8000 ;;
    2)   "$PYTHON" "$DIR/tools_backup.py" backup; echo; read -rp "Press Enter" ;;
    b|B)
      echo
      echo "  b)  Backup"
      echo "  r)  Restore"
      echo "  l)  List backups"
      echo "  x)  Back"
      read -rp "Select: " bk
      case "$bk" in
        b|B) "$PYTHON" "$DIR/tools_backup.py" backup ;;
        r|R) "$PYTHON" "$DIR/tools_backup.py" restore ;;
        l|L) "$PYTHON" "$DIR/tools_backup.py" list ;;
      esac
      echo; read -rp "Press Enter" ;;
    *)   echo "Invalid choice"; echo ;;
  esac
done
